    "import numpy as np\n",
    "sales=np.array([120,340,560,230,150])\n",
    "products=np.array([\"A\",\"B\",\"C\",\"D\",\"E\"])\n",
    "print(products[sales>200])\n",
    "x=np.sort(sales)\n",
    "print(x)\n",
    "print(np.mean(sales))\n",
    "print(np.vstack((sales,products)))\n",
    "print(np.hstack((sales,products)))\n"
   ]
